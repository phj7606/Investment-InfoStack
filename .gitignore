# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 데이터 캐시 — 런타임에 생성되는 파일, 버전 관리 불필요
/data/cache/*.json

# SSH 키 — 절대 커밋 금지
*.key
*.key.pub

# 임시/로컬 파일
*.xlsx
~$*
dashboard-home.png
sector-step1.png
/guide_documents/
/scripts/
/shrimp_data/
/.playwright-mcp/
